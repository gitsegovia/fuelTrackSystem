# Copiar a .env.prod y completar.
# Usar junto con: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up --build
DB_USER=postgres
DB_PASS=GENERATE_A_STRONG_PASSWORD
DB_DATABASE=fueltrack
API_PORT=4000
WEB_PORT=3000
STATION_PORT=3001
# URL pública de la API — Vite la bake en el bundle al hacer build
# Debe ser accesible desde el NAVEGADOR del usuario, no desde dentro de Docker
STATION_GRAPHQL_URI=https://api.tudominio.com/graphql
# Interfaz de red del host Linux (ver con: ip link show)
NET_IFACE=eth0
