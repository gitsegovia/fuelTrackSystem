{
    "name": "fueltrackapi",
    "version": "1.0.0",
    "type": "module",
    "description": "API GraphQL para sistema de estaciones con Node.js, PostgreSQL, Apollo Server Y TypeScript",
    "main": "dist/app.js",
    "scripts": {
        "start": "node dist/app.js",
        "dev": "nodemon --exec \"node --loader ts-node/esm --experimental-specifier-resolution=node --trace-uncaught\" src/app.ts",
        "start:dev": "nodemon --exec \"node --loader ts-node/esm --experimental-specifier-resolution=node --trace-uncaught\" src/app.ts",
        "build": "tsc",
        "seed": "node --loader ts-node/esm --experimental-specifier-resolution=node src/seeders/seed.ts",
        "bootstrap": "node --loader ts-node/esm --experimental-specifier-resolution=node src/scripts/bootstrap-admin.ts --"
    },
    "keywords": [
        "nodejs",
        "graphql",
        "postgresql",
        "apollo-server",
        "api",
        "FuelTrack",
        "estaciones-servicio",
        "jwt",
        "typescript"
    ],
    "author": {
        "name": "José G. Segovia R."
    },
    "license": "MIT",
    "dependencies": {
        "@apollo/server": "4.12.2",
        "@as-integrations/express5": "1.1.0",
        "@graphql-tools/load-files": "7.0.1",
        "@graphql-tools/merge": "9.0.24",
        "@graphql-tools/utils": "10.8.6",
        "axios": "1.16.1",
        "bcryptjs": "3.0.2",
        "cors": "2.8.5",
        "dotenv": "17.0.0",
        "express": "5.1.0",
        "graphql": "16.11.0",
        "graphql-scalars": "1.24.2",
        "jsonwebtoken": "9.0.2",
        "pg": "8.16.3",
        "pg-hstore": "2.3.4",
        "sequelize": "6.37.7",
        "sequelize-cli": "6.6.5"
    },
    "devDependencies": {
        "@types/bcryptjs": "3.0.0",
        "@types/cors": "2.8.19",
        "@types/express": "5.0.6",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "24.12.4",
        "@types/pg": "8.20.0",
        "@types/sequelize": "4.28.20",
        "nodemon": "3.1.14",
        "ts-node": "10.9.2",
        "tsconfig-paths": "4.2.0",
        "typescript": "5.9.3"
    }
}
