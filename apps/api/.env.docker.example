# Copiar a apps/api/.env.docker y completar los valores.
# Usado por docker-compose.yml via env_file (demo y producción).
# Generar JWT_SECRET y DB_PASS con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NODE_ENV=production
PORT=3000

DB_DATABASE=fueltrack
DB_USER=postgres
DB_PASS=GENERATE_A_STRONG_PASSWORD
DB_HOST=db
DB_PORT=5432
DB_HOST_PORT=5433
DB_CONNECTOR=postgres

JWT_SECRET=GENERATE_A_STRONG_SECRET

# Licencia CCI — usar DEV-LICENSE-KEY-12345 solo en demo con CCILicenseServer local
LICENSE_KEY=YOUR_LICENSE_KEY_HERE
# Demo:       http://host.docker.internal:4100
# Producción: https://licenses.cciserver.com/api  (URL real del servidor CCI)
LICENSE_SERVER_URL=http://host.docker.internal:4100
FINGERPRINT_PATH=/etc/fueltrack/fingerprint
